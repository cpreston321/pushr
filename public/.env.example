# Convex deployment URLs. Filled in automatically by `bunx convex dev` on first run.
CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SITE_URL=

# ─── Convex-side env vars (set with `bunx convex env set <NAME> <VALUE>`) ───
# These live in your Convex deployment, not in this .env. Listed here so you
# know what to configure. Re-run `bunx convex env set` after editing.

# REQUIRED — Better Auth signing secret. Generate with: openssl rand -hex 32
# BETTER_AUTH_SECRET=

# REQUIRED — Public site URL of your Convex deployment (the `.convex.site`
# host, not `.convex.cloud`). Used by Better Auth as the auth base URL.
# SITE_URL=https://<your-deployment>.convex.site

# OPTIONAL — Expo push access token. Without it pushr uses the unauthenticated
# Expo Push API which is rate-limited but works fine for personal use.
# Get one from https://expo.dev/accounts/[account]/settings/access-tokens
# EXPO_ACCESS_TOKEN=

# OPTIONAL — URL returned in 429 responses when a user hits their monthly
# push quota. Omit if you don't gate on tier limits.
# UPGRADE_URL=https://example.com/upgrade

# ─── iOS Live Activities (optional) ─────────────────────────────────────────
# Required only if you want to drive Live Activities (lockscreen / Dynamic
# Island progress) from /notify. Leave unset to skip — regular pushes still
# work without these.
#
# Generate the .p8 key in Apple Developer → Keys with "Apple Push
# Notifications service (APNs)" enabled.

# APNS_AUTH_KEY=         # Full .p8 contents, including BEGIN/END headers
# APNS_KEY_ID=           # 10-char key id from the Apple developer console
# APNS_TEAM_ID=          # 10-char Apple Developer Team ID
# APNS_BUNDLE_ID=        # Your iOS app bundle id (must match the client)
# APNS_ENVIRONMENT=      # "sandbox" (Xcode debug) or "production" (TestFlight/App Store)
